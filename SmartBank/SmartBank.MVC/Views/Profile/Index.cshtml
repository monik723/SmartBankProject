@model SmartBank.Core.DTOs.Profile.ProfileDto
@{
    ViewData["Title"] = "My Profile";
}
<div class="container mt-4">
    <h3 class="fw-bold mb-4"><i class="fas fa-user-circle text-primary me-2"></i>My Profile</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i>@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger"><i class="fas fa-times-circle me-2"></i>@TempData["Error"]</div>
    }

    <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
        <form method="post" asp-action="Update" asp-controller="Profile">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Full Name</label>
                    <input name="FullName" value="@Model?.FullName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Email</label>
                    <input value="@Model?.Email" class="form-control" readonly />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Mobile</label>
                    <input name="Mobile" value="@Model?.Mobile" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Gender</label>
                    <select name="Gender" class="form-select">
                        <option value="">Select</option>
                        <option value="Male">Male</option>
                        <option value="Female">Female</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Date of Birth</label>
                    <input name="DateOfBirth" type="date" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Pin Code</label>
                    <input name="PinCode" value="@Model?.PinCode" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">Address</label>
                    <input name="Address" value="@Model?.Address" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">City</label>
                    <input name="City" value="@Model?.City" class="form-control" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">State</label>
                    <input name="State" value="@Model?.State" class="form-control" />
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="fas fa-save me-2"></i>Save Changes
                </button>
                <a href="/Dashboard/Index" class="btn btn-outline-secondary ms-2">Back</a>
            </div>
        </form>
    </div>
</div>
