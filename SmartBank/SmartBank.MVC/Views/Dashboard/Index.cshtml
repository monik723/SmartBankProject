@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h3 class="fw-bold text-dark">
                <i class="fas fa-tachometer-alt me-2 text-primary"></i>
                Welcome, @ViewBag.UserName!
            </h3>
            <p class="text-muted">You are logged in as <strong>@ViewBag.Role</strong> — @ViewBag.Email</p>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background: linear-gradient(135deg,#1a3c5e,#2d6a9f);">
                <i class="fas fa-wallet fa-2x text-white mb-2"></i>
                <h6 class="text-white mb-0">My Accounts</h6>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background: linear-gradient(135deg,#1a6e3c,#28a745);">
                <i class="fas fa-exchange-alt fa-2x text-white mb-2"></i>
                <h6 class="text-white mb-0">Transactions</h6>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background: linear-gradient(135deg,#7b1fa2,#ab47bc);">
                <i class="fas fa-hand-holding-usd fa-2x text-white mb-2"></i>
                <h6 class="text-white mb-0">Loan Apply</h6>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background: linear-gradient(135deg,#e65100,#ff7043);">
                <i class="fas fa-headset fa-2x text-white mb-2"></i>
                <h6 class="text-white mb-0">Support</h6>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm p-4" style="border-radius:12px;">
                <h5 class="fw-bold mb-3"><i class="fas fa-check-circle text-success me-2"></i>Sprint 1 Complete</h5>
                <ul class="list-unstyled mb-0">
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>User Registration API working</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>User Login API working</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>JWT Token generated</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>Protected API working</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>MVC Login page working</li>
                    <li class="mb-2"><i class="fas fa-check text-success me-2"></i>MVC Register page working</li>
                </ul>
            </div>
        </div>
    </div>
</div>
