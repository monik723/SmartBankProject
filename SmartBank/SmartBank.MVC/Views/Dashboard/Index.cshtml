@{
    ViewData["Title"] = "Dashboard";
}
<div class="container mt-4">
    <div class="row mb-4">
        <div class="col">
            <h3 class="fw-bold text-dark">
                <i class="fas fa-tachometer-alt me-2 text-primary"></i>
                Welcome, @ViewBag.UserName!
            </h3>
            <p class="text-muted">Logged in as <strong>@ViewBag.Role</strong> — @ViewBag.Email</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-md-3">
            <a href="/Profile/Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background:linear-gradient(135deg,#1a3c5e,#2d6a9f);">
                    <i class="fas fa-user fa-2x text-white mb-2"></i>
                    <h6 class="text-white mb-0">My Profile</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Account/Index" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background:linear-gradient(135deg,#1a6e3c,#28a745);">
                    <i class="fas fa-wallet fa-2x text-white mb-2"></i>
                    <h6 class="text-white mb-0">My Accounts</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a href="/Account/Open" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background:linear-gradient(135deg,#7b1fa2,#ab47bc);">
                    <i class="fas fa-plus-circle fa-2x text-white mb-2"></i>
                    <h6 class="text-white mb-0">Open Account</h6>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm text-center p-4" style="border-radius:12px; background:linear-gradient(135deg,#e65100,#ff7043);">
                <i class="fas fa-headset fa-2x text-white mb-2"></i>
                <h6 class="text-white mb-0">Support</h6>
            </div>
        </div>
    </div>
</div>
